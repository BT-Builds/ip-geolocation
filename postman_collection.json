{
  "info": {
    "name": "ip-geolocation API",
    "description": "Get location data from IP addresses using ipapi.co free service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://ip-geolocation-liard.vercel.app",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "free-demo-key",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Lookup Ip",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/lookup",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "lookup"
          ]
        }
      }
    },
    {
      "name": "Validate Ip Endpoint",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/validate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "validate"
          ]
        }
      }
    }
  ]
}